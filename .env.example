# MongoDB connection string from MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/bhat_overseas?retryWrites=true&w=majority

# Admin login credentials (used by /api/admin/auth on first deploy)
ADMIN_EMAIL=admin@bhatoverseas.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!

# JWT secret used to sign admin auth tokens (use a long random string)
JWT_SECRET=replace-with-a-long-random-string-of-at-least-32-characters

# Public site URL (used for SEO / sitemap)
NEXT_PUBLIC_SITE_URL=https://bhatoverseas.com

# WhatsApp number (international format, no +)
NEXT_PUBLIC_WHATSAPP=9779800000000

# Contact info shown on the site
NEXT_PUBLIC_PHONE=+977 9800000000
NEXT_PUBLIC_EMAIL=info@bhatoverseas.com
NEXT_PUBLIC_ADDRESS=Kathmandu, Nepal
